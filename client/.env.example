# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Fast2SMS API Configuration
# Get your API key from: https://www.fast2sms.com/dashboard/dev-api
VITE_FAST2SMS_API_KEY=your_fast2sms_api_key_here

# JWT Secret for Token Generation
# Change this to a strong random string in production
VITE_JWT_SECRET=your_secure_jwt_secret_here
